{
  "name": "@fiatconnect/fiatconnect-sdk",
  "version": "0.5.4",
  "description": "A helper library for wallets to integrate with FiatConnect APIs",
  "scripts": {
    "format": "prettier --loglevel error --write \"./**/*.ts\"",
    "prepublish": "rm -rf dist && tsc",
    "release": "npx semantic-release",
    "lint": "eslint --ext=.ts src/",
    "test": "jest",
    "prepare": "husky install"
  },
  "prettier": "@valora/prettier-config",
  "keywords": [
    "fiatconnect",
    "sdk",
    "api",
    "celo"
  ],
  "main": "dist/index-node.js",
  "browser": "dist/index-browser.js",
  "react-native": "dist/index-react-native.js",
  "types": "dist/index-node.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/fiatconnect/fiatconnect-sdk.git"
  },
  "author": "Jacob Waterman <jacob.waterman@valoraapp.com>",
  "bugs": {
    "url": "https://github.com/fiatconnect/fiatconnect-sdk/issues"
  },
  "homepage": "https://github.com/fiatconnect/fiatconnect-sdk#readme",
  "license": "MIT",
  "private": false,
  "devDependencies": {
    "@valora/react-native-cookies": "^6.2.3",
    "@types/jest": "^30.0.0",
    "@types/node-fetch": "^2.6.13",
    "@types/tough-cookie": "^4.0.5",
    "@types/uuid": "^8.3.4",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@valora/eslint-config-typescript": "^0.0.1",
    "@valora/prettier-config": "^0.0.1",
    "commit-and-tag-version": "^9.6.0",
    "conventional-changelog-conventionalcommits": "^6.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-native": "^4.1.0",
    "husky": "^7.0.4",
    "jest": "^30.3.0",
    "jest-fetch-mock": "https://github.com/jefflau/jest-fetch-mock#69882ba",
    "prettier": "3.8.2",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@valora/react-native-cookies": "^6.2.3"
  },
  "peerDependenciesMeta": {
    "@valora/react-native-cookies": {
      "optional": true
    }
  },
  "dependencies": {
    "@badrap/result": "^0.2.13",
    "@fiatconnect/fiatconnect-types": "^13.3.50",
    "cross-fetch": "^4.1.0",
    "ethers": "^6.16.0",
    "fetch-cookie": "^3.0.1",
    "siwe": "^3.0.0",
    "tough-cookie": "^6.0.1",
    "tslib": "^2.8.1",
    "zod": "^3.25.76"
  },
  "release": {
    "branches": [
      "main"
    ],
    "preset": "conventionalcommits"
  }
}
